#!/usr/bin/env bash
# claude-browse - Session-grouped browser window management for AI agent workflows
#
# Opens URLs/files in the browser with session-aware window grouping:
# - First open in a session creates a new browser window
# - Subsequent opens become tabs in that window
# - Falls back to xdg-open/open if no session-aware browser is available
#
# Environment:
#   CLAUDE_BROWSE_STATE - Path to session state file (set by Claude wrapper scripts)
#                         If unset, every open creates a new window (no grouping)

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: claude-browse <url-or-path>" >&2
  exit 1
fi

url="$1"

# Determine if this is the first open in the session
new_window=true
if [[ -n "${CLAUDE_BROWSE_STATE:-}" ]]; then
  if [[ -f "$CLAUDE_BROWSE_STATE" ]]; then
    new_window=false
  else
    touch "$CLAUDE_BROWSE_STATE"
  fi
fi

# Detect platform
is_wsl=false
if [[ -n "${WSL_DISTRO_NAME:-${WSL_DISTRO:-}}" ]] || grep -qi microsoft /proc/version 2>/dev/null; then
  is_wsl=true
fi

# Convert a Linux path to a Windows-accessible path for WSL.
# Uses wslpath if available, otherwise constructs \\wsl.localhost\DISTRO\path manually.
# URLs (http://, https://, file://) pass through unchanged.
wsl_winpath() {
  local path="$1"
  # URLs don't need conversion
  if [[ "$path" =~ ^https?:// ]] || [[ "$path" =~ ^file:// ]]; then
    echo "$path"
    return
  fi
  # Resolve to absolute path
  if [[ -e "$path" ]]; then
    path="$(cd "$(dirname "$path")" && pwd)/$(basename "$path")"
  fi
  # Use wslpath if available
  if command -v wslpath &>/dev/null; then
    wslpath -w "$path"
    return
  fi
  # Determine distro name: WSL_DISTRO_NAME (standard), WSL_DISTRO (NixOS WSL), or wsl.exe query
  local distro="${WSL_DISTRO_NAME:-${WSL_DISTRO:-}}"
  if [[ -z "$distro" ]]; then
    # wsl.exe -l -q lists distros; the default (running) one is usually first
    # Output has null bytes from UTF-16, strip them
    distro=$(wsl.exe -l -q 2>/dev/null | tr -d '\0\r' | head -1)
  fi
  if [[ -z "$distro" ]]; then
    # Can't determine distro name - return empty to signal caller should use wslview
    return 1
  fi
  # Convert /mnt/c/... paths to C:\...
  if [[ "$path" =~ ^/mnt/([a-zA-Z])/(.*) ]]; then
    local drive="${BASH_REMATCH[1]^^}"
    local rest="${BASH_REMATCH[2]}"
    printf '%s\n' "${drive}:\\${rest//\//\\}"
  else
    # Linux paths become \\wsl.localhost\distro\path
    printf '%s\n' "\\\\wsl.localhost\\${distro}${path//\//\\}"
  fi
}

# Find Edge on WSL by checking known install paths
find_edge_wsl() {
  local candidates=(
    "msedge.exe"
    "/mnt/c/Program Files (x86)/Microsoft/Edge/Application/msedge.exe"
    "/mnt/c/Program Files/Microsoft/Edge/Application/msedge.exe"
  )
  for c in "${candidates[@]}"; do
    if command -v "$c" &>/dev/null || [[ -x "$c" ]]; then
      echo "$c"
      return 0
    fi
  done
  return 1
}

# Open appropriately
if [[ "$is_wsl" == true ]]; then
  # WSL: use msedge.exe directly (bypasses wslview overhead, enables window control)
  # Must convert Linux paths to Windows-accessible paths for Windows executables
  if win_url=$(wsl_winpath "$url") && edge_cmd=$(find_edge_wsl); then
    if [[ "$new_window" == true ]]; then
      "$edge_cmd" --new-window "$win_url" &>/dev/null &
    else
      "$edge_cmd" "$win_url" &>/dev/null &
    fi
  elif command -v wslview &>/dev/null; then
    # wslview handles path conversion internally
    wslview "$url"
  else
    echo "Error: No browser found (tried msedge.exe, wslview)" >&2
    exit 1
  fi

elif [[ "${OSTYPE:-}" == darwin* ]]; then
  # macOS: use open -a for Edge, fall back to plain open
  if [[ -d "/Applications/Microsoft Edge.app" ]]; then
    if [[ "$new_window" == true ]]; then
      open -na "Microsoft Edge" --args --new-window "$url"
    else
      open -a "Microsoft Edge" "$url"
    fi
  else
    open "$url"
  fi

else
  # Bare Linux: try microsoft-edge, then xdg-open
  if command -v microsoft-edge &>/dev/null; then
    if [[ "$new_window" == true ]]; then
      microsoft-edge --new-window "$url" &>/dev/null &
    else
      microsoft-edge "$url" &>/dev/null &
    fi
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$url"
  else
    echo "Error: No browser found (tried microsoft-edge, xdg-open)" >&2
    exit 1
  fi
fi
