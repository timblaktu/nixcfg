{
  "If Statement": {
    "prefix": "iff",
    "body": [
      "if ${1:condition}; then",
      "  $0",
      "fi"
    ],
    "description": "if-then-fi block"
  },
  "For Loop": {
    "prefix": "fori",
    "body": [
      "for ${1:item} in ${2:list}; do",
      "  $0",
      "done"
    ],
    "description": "for-in-do-done loop"
  },
  "Case Statement": {
    "prefix": "case",
    "body": [
      "case \"${1:variable}\" in",
      "  ${2:pattern})",
      "    $0",
      "    ;;",
      "  *)",
      "    echo \"Unknown: \\$${1:variable}\"",
      "    ;;",
      "esac"
    ],
    "description": "case statement skeleton"
  }
}
